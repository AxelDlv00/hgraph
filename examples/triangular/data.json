{"title": "Triangular numbers", "mode": "doc", "chapters": [{"title": "Introduction", "blocks": [{"t": "head", "level": 2, "title": "Triangular numbers", "num": "1.1"}, {"t": "stmt", "label": "def:triangular", "labels": ["def:triangular"], "title": "Triangular number", "content_type": "definition", "lean": ["Triangular.IsTriangular"], "uses": [], "leanok": true, "mathlibok": false, "sketch": false, "level": null, "ref": null, "body": "A natural number $m$ is \\emph{triangular} if $m = T_n := 1 + 2 + \\cdots + n$\nfor some $n$.", "num": "1.1", "abbr": "Def", "id": "9ad69793826a", "enrich": {"lean_status": "lean_ok", "mathlib_name": null, "reviewed": false, "maths_verdict": null, "lean_verdict": null, "lean": [{"name": "Triangular.IsTriangular", "status": "lean_ok", "file": "Lean/Triangular.lean", "code": "def IsTriangular (m : Nat) : Prop := ∃ n, m = T n"}], "deps": [], "reviews": [], "comments": [], "status": null, "tags": null, "ref": null, "sketch": false}}, {"t": "stmt", "label": "thm:triangular-closed-form", "labels": ["thm:triangular-closed-form"], "title": "Closed form", "content_type": "theorem", "lean": ["Triangular.closed_form"], "uses": ["def:triangular"], "leanok": true, "mathlibok": false, "sketch": false, "level": null, "ref": null, "body": "$2T_n = n(n+1)$.", "num": "1.2", "abbr": "Thm", "id": "8f04716b99a7", "enrich": {"lean_status": "lean_ok", "mathlib_name": null, "reviewed": true, "maths_verdict": "good", "lean_verdict": "good", "lean": [{"name": "Triangular.closed_form", "status": "lean_ok", "file": "Lean/Triangular.lean", "code": "theorem closed_form (n : Nat) : 2 * T n = n * (n + 1) := by\n  induction n with\n  | zero => rfl\n  | succ k ih => simp [T, Finset.sum_range_succ, Nat.mul_add, ih]; ring"}], "deps": [{"id": "9ad69793826a", "title": "Triangular number", "label": "def:triangular", "type": "uses"}], "reviews": [{"author": "reviewer", "maths_verdict": "good", "maths_comment": "statement and proof sketch are both correct.", "lean_verdict": "good", "lean_comment": "closed_form has no sorry — fully checked.", "created": "2026-07-23T03:22:40", "updated": "2026-07-23T03:22:40"}], "comments": [], "status": null, "tags": null, "ref": null, "sketch": false}}, {"t": "proof", "tex": "By induction on $n$: $T_0 = 0$, and $T_{n+1} = T_n + (n+1)$ splits off the\nlast term."}, {"t": "stmt", "label": "prop:triangular-consecutive-sum", "labels": ["prop:triangular-consecutive-sum"], "title": "Consecutive triangular numbers sum to a square", "content_type": "proposition", "lean": [], "uses": ["thm:triangular-closed-form"], "leanok": false, "mathlibok": false, "sketch": false, "level": null, "ref": null, "body": "$T_{n-1} + T_n = n^2$ for every $n \\geq 1$.", "num": "1.3", "abbr": "Prop", "id": "f3d9ae3f4822", "enrich": {"lean_status": "empty", "mathlib_name": null, "reviewed": false, "maths_verdict": null, "lean_verdict": null, "lean": [], "deps": [{"id": "8f04716b99a7", "title": "Closed form", "label": "thm:triangular-closed-form", "type": "uses"}], "reviews": [], "comments": [], "status": null, "tags": null, "ref": null, "sketch": false}}, {"t": "proof", "tex": "Substitute the closed form for both terms and simplify."}, {"t": "stmt", "label": "cor:triangular-even-odd", "labels": ["cor:triangular-even-odd"], "title": "Parity of triangular numbers", "content_type": "corollary", "lean": [], "uses": ["thm:triangular-closed-form"], "leanok": false, "mathlibok": false, "sketch": false, "level": null, "ref": null, "body": "$T_n$ is even iff $n \\equiv 0$ or $n \\equiv 3 \\pmod 4$.", "num": "1.4", "abbr": "Cor", "id": "b6f70f5536a0", "enrich": {"lean_status": "empty", "mathlib_name": null, "reviewed": true, "maths_verdict": "bad", "lean_verdict": null, "lean": [], "deps": [{"id": "8f04716b99a7", "title": "Closed form", "label": "thm:triangular-closed-form", "type": "uses"}], "reviews": [{"author": "human", "maths_verdict": "bad", "maths_comment": "the residue classes need a cleaner case split.", "lean_verdict": null, "lean_comment": null, "created": "2026-07-23T03:22:40", "updated": "2026-07-23T03:22:40"}], "comments": [], "status": "built", "tags": null, "ref": null, "sketch": false}}, {"t": "proof", "tex": "Immediate from the closed form: $n(n+1)$ is divisible by $4$ exactly in\nthose residue classes."}, {"t": "stmt", "label": "ex:triangular-five", "labels": ["ex:triangular-five"], "title": "$T_5$", "content_type": "example", "lean": [], "uses": ["def:triangular"], "leanok": false, "mathlibok": false, "sketch": false, "level": null, "ref": null, "body": "$T_5 = 1+2+3+4+5 = 15$.", "num": "1.5", "abbr": "Ex", "id": "fec462cc1e68", "enrich": {"lean_status": "empty", "mathlib_name": null, "reviewed": false, "maths_verdict": null, "lean_verdict": null, "lean": [], "deps": [{"id": "9ad69793826a", "title": "Triangular number", "label": "def:triangular", "type": "uses"}], "reviews": [], "comments": [], "status": false, "tags": null, "ref": null, "sketch": false}}, {"t": "stmt", "label": "rem:pascal", "labels": ["rem:pascal"], "title": "Pascal's triangle", "content_type": "remark", "lean": [], "uses": ["def:triangular"], "leanok": false, "mathlibok": false, "sketch": false, "level": null, "ref": null, "body": "The triangular numbers are the third diagonal of Pascal's triangle:\n$T_n = \\binom{n+1}{2}$.", "num": "1.6", "abbr": "Rmk", "id": "748b308b6cb5", "enrich": {"lean_status": "empty", "mathlib_name": null, "reviewed": false, "maths_verdict": null, "lean_verdict": null, "lean": [], "deps": [{"id": "9ad69793826a", "title": "Triangular number", "label": "def:triangular", "type": "uses"}], "reviews": [], "comments": [], "status": null, "tags": null, "ref": null, "sketch": false}}, {"t": "stmt", "label": "conj:square-triangular", "labels": ["conj:square-triangular"], "title": "Illustrative only", "content_type": "conjecture", "lean": [], "uses": [], "leanok": false, "mathlibok": false, "sketch": false, "level": null, "ref": null, "body": "As a placeholder for the \\texttt{conjecture} content type: infinitely many\ntriangular numbers are also perfect squares, as discussed in \\cite{pell1996equation}.\n(This is in fact a theorem, provable via Pell's equation — kept as a\n\\texttt{conjecture} here only to demonstrate the field, not because the claim\nis open.) See also \\cite{conway1996book} for background on classical figurate\nnumbers.", "num": "1.7", "abbr": "Conj", "id": "8cb5a7ef3017", "enrich": {"lean_status": "empty", "mathlib_name": null, "reviewed": false, "maths_verdict": null, "lean_verdict": null, "lean": [], "deps": [], "reviews": [], "comments": [], "status": null, "tags": null, "ref": null, "sketch": false}}], "num": "1"}], "entries": [{"id": "9ad69793826a", "label": "def:triangular", "title": "Triangular number", "chapter": null, "kind": "definition", "level": "coarse", "ref": null, "sketch": false, "body": "A natural number $m$ is \\emph{triangular} if $m = T_n := 1 + 2 + \\cdots + n$\nfor some $n$.", "lean_status": "lean_ok", "mathlib_name": null, "status": null, "tags": null, "lean": [{"name": "Triangular.IsTriangular", "status": "lean_ok", "file": "Lean/Triangular.lean", "code": "def IsTriangular (m : Nat) : Prop := ∃ n, m = T n"}], "deps": [], "reviewed": false, "maths_verdict": null, "lean_verdict": null, "reviews": [], "comments": []}, {"id": "8f04716b99a7", "label": "thm:triangular-closed-form", "title": "Closed form", "chapter": null, "kind": "theorem", "level": "medium", "ref": null, "sketch": false, "body": "$2T_n = n(n+1)$.", "lean_status": "lean_ok", "mathlib_name": null, "status": null, "tags": null, "lean": [{"name": "Triangular.closed_form", "status": "lean_ok", "file": "Lean/Triangular.lean", "code": "theorem closed_form (n : Nat) : 2 * T n = n * (n + 1) := by\n  induction n with\n  | zero => rfl\n  | succ k ih => simp [T, Finset.sum_range_succ, Nat.mul_add, ih]; ring"}], "deps": [{"id": "9ad69793826a", "title": "Triangular number", "label": "def:triangular", "type": "uses"}], "reviewed": true, "maths_verdict": "good", "lean_verdict": "good", "reviews": [{"author": "reviewer", "maths_verdict": "good", "maths_comment": "statement and proof sketch are both correct.", "lean_verdict": "good", "lean_comment": "closed_form has no sorry — fully checked.", "created": "2026-07-23T03:22:40", "updated": "2026-07-23T03:22:40"}], "comments": []}, {"id": "f3d9ae3f4822", "label": "prop:triangular-consecutive-sum", "title": "Consecutive triangular numbers sum to a square", "chapter": null, "kind": "proposition", "level": "medium", "ref": null, "sketch": false, "body": "$T_{n-1} + T_n = n^2$ for every $n \\geq 1$.", "lean_status": "empty", "mathlib_name": null, "status": null, "tags": null, "lean": [], "deps": [{"id": "8f04716b99a7", "title": "Closed form", "label": "thm:triangular-closed-form", "type": "uses"}], "reviewed": false, "maths_verdict": null, "lean_verdict": null, "reviews": [], "comments": []}, {"id": "b6f70f5536a0", "label": "cor:triangular-even-odd", "title": "Parity of triangular numbers", "chapter": null, "kind": "corollary", "level": "fine", "ref": null, "sketch": false, "body": "$T_n$ is even iff $n \\equiv 0$ or $n \\equiv 3 \\pmod 4$.", "lean_status": "empty", "mathlib_name": null, "status": "built", "tags": null, "lean": [], "deps": [{"id": "8f04716b99a7", "title": "Closed form", "label": "thm:triangular-closed-form", "type": "uses"}], "reviewed": true, "maths_verdict": "bad", "lean_verdict": null, "reviews": [{"author": "human", "maths_verdict": "bad", "maths_comment": "the residue classes need a cleaner case split.", "lean_verdict": null, "lean_comment": null, "created": "2026-07-23T03:22:40", "updated": "2026-07-23T03:22:40"}], "comments": []}, {"id": "fec462cc1e68", "label": "ex:triangular-five", "title": "$T_5$", "chapter": null, "kind": "example", "level": "fine", "ref": null, "sketch": false, "body": "$T_5 = 1+2+3+4+5 = 15$.", "lean_status": "empty", "mathlib_name": null, "status": false, "tags": null, "lean": [], "deps": [{"id": "9ad69793826a", "title": "Triangular number", "label": "def:triangular", "type": "uses"}], "reviewed": false, "maths_verdict": null, "lean_verdict": null, "reviews": [], "comments": []}, {"id": "748b308b6cb5", "label": "rem:pascal", "title": "Pascal's triangle", "chapter": null, "kind": "remark", "level": "fine", "ref": null, "sketch": false, "body": "The triangular numbers are the third diagonal of Pascal's triangle:\n$T_n = \\binom{n+1}{2}$.", "lean_status": "empty", "mathlib_name": null, "status": null, "tags": null, "lean": [], "deps": [{"id": "9ad69793826a", "title": "Triangular number", "label": "def:triangular", "type": "uses"}], "reviewed": false, "maths_verdict": null, "lean_verdict": null, "reviews": [], "comments": []}, {"id": "8cb5a7ef3017", "label": "conj:square-triangular", "title": "Illustrative only", "chapter": null, "kind": "conjecture", "level": "fine", "ref": null, "sketch": false, "body": "As a placeholder for the \\texttt{conjecture} content type: infinitely many\ntriangular numbers are also perfect squares, as discussed in \\cite{pell1996equation}.\n(This is in fact a theorem, provable via Pell's equation — kept as a\n\\texttt{conjecture} here only to demonstrate the field, not because the claim\nis open.) See also \\cite{conway1996book} for background on classical figurate\nnumbers.", "lean_status": "empty", "mathlib_name": null, "status": null, "tags": null, "lean": [], "deps": [], "reviewed": false, "maths_verdict": null, "lean_verdict": null, "reviews": [], "comments": []}], "refs": {"def:triangular": {"num": "1.1", "id": "9ad69793826a", "abbr": "Def", "kind": "stmt", "ch": 0, "anchor": "stmt-9ad69793826a"}, "thm:triangular-closed-form": {"num": "1.2", "id": "8f04716b99a7", "abbr": "Thm", "kind": "stmt", "ch": 0, "anchor": "stmt-8f04716b99a7"}, "prop:triangular-consecutive-sum": {"num": "1.3", "id": "f3d9ae3f4822", "abbr": "Prop", "kind": "stmt", "ch": 0, "anchor": "stmt-f3d9ae3f4822"}, "cor:triangular-even-odd": {"num": "1.4", "id": "b6f70f5536a0", "abbr": "Cor", "kind": "stmt", "ch": 0, "anchor": "stmt-b6f70f5536a0"}, "ex:triangular-five": {"num": "1.5", "id": "fec462cc1e68", "abbr": "Ex", "kind": "stmt", "ch": 0, "anchor": "stmt-fec462cc1e68"}, "rem:pascal": {"num": "1.6", "id": "748b308b6cb5", "abbr": "Rmk", "kind": "stmt", "ch": 0, "anchor": "stmt-748b308b6cb5"}, "conj:square-triangular": {"num": "1.7", "id": "8cb5a7ef3017", "abbr": "Conj", "kind": "stmt", "ch": 0, "anchor": "stmt-8cb5a7ef3017"}}, "loc": {"9ad69793826a": 0, "8f04716b99a7": 0, "f3d9ae3f4822": 0, "b6f70f5536a0": 0, "fec462cc1e68": 0, "748b308b6cb5": 0, "8cb5a7ef3017": 0}, "bib": [{"key": "conway1996book", "type": "book", "title": "The Book of Numbers", "author": "Conway, John H. and Guy, Richard K.", "year": "1996", "journal": null, "booktitle": null, "publisher": "Springer", "volume": null, "number": null, "pages": null, "url": null}, {"key": "pell1996equation", "type": "article", "title": "On Square Triangular Numbers", "author": "Pell, John", "year": "1996", "journal": "Journal of Recreational Mathematics", "booktitle": null, "publisher": null, "volume": "12", "number": "3", "pages": "45--52", "url": "https://example.org/pell-1996"}], "docTitle": "Triangular numbers", "docAuthor": null, "macros": {}, "repo": "AxelDlv00/hgraph", "gvsvg": {}}